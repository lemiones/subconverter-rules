{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "dns-direct",
        "address": "https://223.5.5.5/dns-query",
        "detour": "direct"
      },
      {
        "tag": "dns-proxy",
        "address": "https://8.8.8.8/dns-query",
        "detour": "proxy"
      }
    ],
    "rules": [
      {
        "geosite": "cn",
        "server": "dns-direct"
      },
      {
        "geosite": "geolocation-!cn",
        "server": "dns-proxy"
      }
    ],
    "final": "dns-proxy"
  },
  "inbounds": [
    {
      "listen": "127.0.0.1",
      "listen_port": 65535,
      "tag": "mixed-in",
      "type": "mixed",
      "users": []
    }
  ],
  "outbounds": [],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "local",
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol":"dns",
        "action":"hijack-dns"
      },
      {
        "geosite":"cn",
        "outbound":"direct"
      },
      {
        "geoip":"cn",
        "outbound":"direct"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      }
    ],
    "final":"proxy"
  },
  "experimental": {
    
  }
}
