{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "dns-proxy",
        "type": "https",
        "server": "8.8.8.8",
        "path": "/dns-query"
      },
      {
        "tag": "dns-direct",
        "type": "https",
        "server": "223.5.5.5",
        "path": "/dns-query"
      }
    ],
    "rules": [
      {
        "rule_set": ["geosite-cn"],
        "server": "dns-direct"
      }
    ],
    "final": "dns-proxy"
  },
  "inbounds": [
    {
      "listen": "127.0.0.1",
      "listen_port": 65535,
      "tag": "mixed-in",
      "type": "mixed",
      "users": []
    }
  ],
  "outbounds": [],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "local",
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol":"dns",
        "action":"hijack-dns"
      },
      {
        "rule_set": ["geosite-cn"],
        "outbound":"direct"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      }
    ],
    "rule_set": [
      {
        "tag": "geosite-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://fastly.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-cn.srs",
        "download_detour": "direct"
      }
     ]
  },
  "experimental": {
    
  }
}
